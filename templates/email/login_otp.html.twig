{% extends 'email/base.html.twig' %}

{% block title %}Your login code{% endblock %}

{% block content %}
    <h1 style="margin:0 0 16px; font-size:20px;">Your login code</h1>
    <p style="margin:0 0 16px;">Hi {{ first_name }},</p>
    <p style="margin:0 0 16px; line-height:1.5;">Use the code below to finish signing in. It expires in {{ ttl_minutes }} minutes.</p>
    <p style="margin:24px 0; text-align:center;">
        <span style="display:inline-block; font-size:32px; font-weight:bold; letter-spacing:8px; background:#f4f4f5; padding:16px 24px; border-radius:12px;">{{ code }}</span>
    </p>
    <p style="margin:0; color:#71717a; font-size:13px;">If you didn't try to sign in, you can ignore this email and your account stays secure.</p>
{% endblock %}
