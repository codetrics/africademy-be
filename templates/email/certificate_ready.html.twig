{% extends 'email/base.html.twig' %}

{% block title %}Your certificate is ready{% endblock %}

{% block content %}
    <h1 style="margin:0 0 16px; font-size:20px;">Congratulations, {{ first_name }}!</h1>
    <p style="margin:0 0 16px; line-height:1.5;">You've completed <strong>{{ course_title }}</strong> and earned your certificate of completion.</p>
    <p style="margin:0 0 16px; line-height:1.5;">Sign in to download your certificate as a PDF from your certificates page.</p>
    <p style="margin:24px 0; line-height:1.5;">
        Anyone can confirm it's genuine using your credential ID:<br>
        <span style="display:inline-block; margin-top:8px; font-size:14px; letter-spacing:1px; background:#f4f4f5; padding:12px 16px; border-radius:8px;">{{ credential_id }}</span>
    </p>
    <p style="margin:0; color:#71717a; font-size:13px;">Keep learning — your next course is waiting.</p>
{% endblock %}
