{% extends 'email/base.html.twig' %}

{% block title %}New website enquiry{% endblock %}

{% block content %}
    <h1 style="margin:0 0 16px; font-size:20px;">New website enquiry</h1>
    <p style="margin:0 0 16px; line-height:1.5;">A new enquiry has been submitted through the website.</p>

    <table cellpadding="0" cellspacing="0" style="width:100%; border-collapse:collapse;">
        <tr>
            <td style="padding:8px 0; font-weight:bold; width:120px; vertical-align:top;">Full name</td>
            <td style="padding:8px 0;">{{ full_name }}</td>
        </tr>
        <tr>
            <td style="padding:8px 0; font-weight:bold; vertical-align:top;">Email</td>
            <td style="padding:8px 0;"><a href="mailto:{{ email }}">{{ email }}</a></td>
        </tr>
        <tr>
            <td style="padding:8px 0; font-weight:bold; vertical-align:top;">Subject</td>
            <td style="padding:8px 0;">{{ subject }}</td>
        </tr>
        <tr>
            <td style="padding:8px 0; font-weight:bold; vertical-align:top;">Message</td>
            <td style="padding:8px 0; line-height:1.5; white-space:pre-line;">{{ message }}</td>
        </tr>
    </table>
{% endblock %}
