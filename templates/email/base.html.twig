<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Africademy{% endblock %}</title>
    </head>
    <body style="margin:0; padding:0; background:#f4f4f5; font-family:Arial, Helvetica, sans-serif; color:#18181b;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5; padding:24px 0;">
            <tr>
                <td align="center">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; background:#ffffff; border-radius:12px; overflow:hidden;">
                        <tr>
                            <td style="background:#18181b; padding:20px 32px;">
                                <span style="color:#ffffff; font-size:18px; font-weight:bold;">Africademy</span>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:32px;">
                                {% block content %}{% endblock %}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:20px 32px; border-top:1px solid #e4e4e7; color:#71717a; font-size:12px;">
                                You are receiving this email because of activity on your Africademy account.
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
